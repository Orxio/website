# Site
# Canonical production URL. Used to build canonical links, OpenGraph/Twitter
# metadata, sitemap.xml, and robots.txt. Falls back to https://orxio.ai if unset.
NEXT_PUBLIC_SITE_URL=

# Public contact details
# Client-visible values rendered directly in the UI (Footer, legal pages).
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_LINKEDIN_URL=

# Contact form — Resend
# Server-only. Used by the contact form Server Action (app/actions/contact.ts)
# to send the internal notification and prospect acknowledgement emails.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
CONTACT_INBOX_EMAIL=
